{
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml",
          "context/**.md",
          "architecture/**.md",
          "adr/**.md",
          "plans/**.md",
          "api/**.md",
          "configuration/**.md",
          "integrations/**.md",
          "security/**.md",
          "guides/**.md",
          "operations/**.md",
          "migrations/**.md",
          "changelog/**.md"
        ],
        "exclude": [
          "**/_*.md"
        ]
      },
      {
        "files": [
          "**.md",
          "**/toc.yml",
          "toc.yml"
        ],
        "src": "archive",
        "dest": "archive"
      }
    ],
    "resource": [
      {
        "files": [
          "assets/**",
          "robots.txt",
          "CNAME",
          ".nojekyll",
          "llms.txt",
          "kitty-specs/**/*.html",
          "kitty-specs/toc.yml"
        ]
      }
    ],
    "overwrite": [
      {
        "files": [
          "apidoc/**.md"
        ],
        "exclude": [
          "obj/**",
          "_site/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern",
      "templates/spec-kitty"
    ],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false,
    "globalMetadata": {
      "_appTitle": "Spec Kitty Documentation",
      "_appName": "Spec Kitty",
      "_siteUrl": "https://docs.spec-kitty.ai/",
      "_appFooter": "Spec Kitty documentation — context, architecture, ADRs, plans, API, configuration, integrations, security, guides, operations, migrations, and changelog · <a href=\"https://docs.spec-kitty.ai/archive/1x/\">1.x historical archive</a> · <a href=\"https://docs.spec-kitty.ai/archive/2x/\">2.x historical archive</a>",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/Priivacy-ai/spec-kitty",
        "branch": "main"
      },
      "_appLogoPath": "assets/images/logo_small.webp",
      "_appFaviconPath": "assets/images/favicon.png"
    }
  }
}
