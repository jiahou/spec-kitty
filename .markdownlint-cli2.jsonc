{
  "$schema": "https://json.schemastore.org/markdownlint-cli2.json",
  "config": {
    "default": true,
    "MD001": false,
    "MD003": false,
    "MD005": false,
    "MD013": false,
    "MD024": false,
    "MD025": false,
    "MD028": false,
    "MD029": false,
    "MD031": false,
    "MD032": false,
    "MD033": false,
    "MD034": false,
    "MD035": false,
    "MD036": false,
    "MD040": false,
    "MD041": false,
    "MD046": false,
    "MD051": false,
    "MD052": false,
    "MD055": false,
    "MD056": false
  },
  "ignores": [
    ".git/**",
    ".venv/**",
    ".worktrees/**",
    ".pytest_cache/**",
    "node_modules/**",
    "kitty-specs/**",
    ".kittify/**",
    ".claude/**",
    ".agents/**",
    ".github/prompts/**",
    ".cursor/**",
    ".windsurf/**",
    ".kilocode/**",
    ".augment/**",
    ".roo/**",
    ".amazonq/**",
    ".kiro/**",
    ".gemini/**",
    ".qwen/**",
    ".opencode/**",
    ".agent/**",
    ".codex/**",
    "mutants/**",
    "doctrine_ref/**",
    "work/**",
    "research/**",
    "tests/specify_cli/regression/**",
    "tests/specify_cli/skills/__snapshots__/**",
    "tests/retrospective/fixtures/**",
    "src/doctrine/**",
    "src/specify_cli/missions/**",
    "src/specify_cli/templates/**",
    "examples/**",
    "scripts/**",
    "glossary/**",
    "docs/engineering_notes/**",
    "docs/development/**",
    "docs/p0-baseline-refresh.md"
  ]
}
