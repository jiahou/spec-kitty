{"aggregate_id": "01KVBBT6FEQ01NHNSQD7X8JTPE", "aggregate_type": "Mission", "event_id": "01KVBBT6W9C24PGHW3K4KJH1W1", "event_type": "MissionCreated", "payload": {"created_at": "2026-06-17T17:59:37.711588+00:00", "friendly_name": "Canonical Path-Trust & Guard-Capability Seams", "mission_id": "01KVBBT6FEQ01NHNSQD7X8JTPE", "mission_number": null, "mission_slug": "canonical-seams-path-trust-guard-capability-01KVBBT6", "mission_type": "software-dev", "purpose_context": "Today the same 'is this slug a safe path segment' and 'is this path under a trusted root' decisions are re-implemented in several places while the canonical path-assembly seam validates nothing, and an architectural CI gate can be silently skipped on guarded-surface edits. This mission binds those decisions to single canonical seams (one validator, one containment utility) and closes the CI gap, so the next would-be bypass becomes a test failure rather than a silent regression.", "purpose_tldr": "Bind path-trust validation into the Shared Kernel so every caller inherits it, and un-mask the architectural CI gate.", "target_branch": "feat/canonical-seams-path-trust-guard-capability", "wp_count": 0}, "project_slug": "spec-kitty", "project_uuid": "8a4a7da6-a97c-4bb4-893a-b31664abfee4", "schema_version": "5.0.0", "timestamp": "2026-06-17T17:59:38.121297+00:00"}
